# ===========================================
# Model Monitoring & Drift Detection Config
# ===========================================

# Application
APP_NAME=model-monitoring-drift
APP_ENV=development
APP_PORT=8000
DEBUG=true

# Model Configuration
MODEL_PATH=./models/production_model.pkl
REFERENCE_DATA_PATH=./data/reference.csv
CURRENT_DATA_PATH=./data/current.csv

# Drift Detection Thresholds
DRIFT_THRESHOLD=0.05
PSI_THRESHOLD=0.2
KS_THRESHOLD=0.05
PERFORMANCE_DEGRADATION_THRESHOLD=0.05

# Alerting
ALERT_ENABLED=true
ALERT_WEBHOOK_URL=http://localhost:9093/api/v1/alerts
PAGERDUTY_API_KEY=your-pagerduty-key-here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Alertmanager
ALERTMANAGER_PORT=9093

# Retraining
RETRAINING_ENABLED=true
RETRAINING_MIN_SAMPLES=1000
RETRAINING_VALIDATION_SPLIT=0.2
RETRAINING_PIPELINE_URL=http://localhost:8080/api/v1/pipelines/retrain

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database (for storing monitoring results)
DATABASE_URL=sqlite:///./monitoring.db
